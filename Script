            checkHealth(healthStatusLabel, healthValueLabel)
        end)
    else
        if healthStatusLabel then healthStatusLabel.Text = "Status: Auto-TP disabled" end
        if healthConnection then
            healthConnection:Disconnect()
            healthConnection = nil
        end
    end
end

