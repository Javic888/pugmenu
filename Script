-- ============================================
-- CHEST CYCLE
-- ============================================
local isChestRunning = false
local chestCurrentIndex = 1
local chestCurrentTypeIndex = 1
local objectTypes = {"SmallChest", "LargeChest", "SmallSafe", "LargeSafe", "MediumSafe"}

local function findAllModels(objectType)
    local foundModels = {}
    local success, folder = pcall(function() return workspace.Game.Entities[objectType] end)
    if success and folder then
        for _, obj in ipairs(folder:GetChildren()) do
            if obj:IsA("Model") and obj.Name == objectType then
                table.insert(foundModels, obj)
            end
        end
    end
    return foundModels
end

local function refreshAllTypes(statusLabel)
    local counts = {}
    for _, objectType in ipairs(objectTypes) do
        local models = findAllModels(objectType)
        counts[objectType] = #models
    end
    if statusLabel then
        statusLabel.Text = "SmlCh: " .. counts.SmallChest .. " | LrgCh: " .. counts.LargeChest .. 
                          " | SmlSf: " .. counts.SmallSafe .. " | LrgSf: " .. counts.LargeSafe .. 
                          " | MedSf: " .. counts.MediumSafe
    end
    return counts
end

_G.startChestCycle = function(statusLabel)
    if isChestRunning then return end
    isChestRunning = true
    if statusLabel then statusLabel.Text = "Cycle started" end
    coroutine.wrap(function()
        while isChestRunning do
            refreshAllTypes(statusLabel)
            local currentType = objectTypes[chestCurrentTypeIndex]
            local models = findAllModels(currentType)
            if #models == 0 then
                if statusLabel then statusLabel.Text = "No " .. currentType end
                chestCurrentTypeIndex = chestCurrentTypeIndex + 1
                if chestCurrentTypeIndex > #objectTypes then chestCurrentTypeIndex = 1 end
                task.wait(2)
            else
                if chestCurrentIndex > #models then chestCurrentIndex = 1 end
                local obj = models[chestCurrentIndex]
                if obj and obj.Parent then
                    local character = LocalPlayer.Character
                    if character then
                        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
                        if humanoidRootPart then
                            local targetPart = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                            if targetPart then
                                humanoidRootPart.CFrame = targetPart.CFrame + Vector3.new(0, 5, 0)
                                if statusLabel then
                                    statusLabel.Text = currentType .. " " .. chestCurrentIndex .. "/" .. #models
                                end
                            end
                        end
                    end
                    chestCurrentIndex = chestCurrentIndex + 1
                    if chestCurrentIndex > #models then
                        chestCurrentTypeIndex = chestCurrentTypeIndex + 1
                        if chestCurrentTypeIndex > #objectTypes then chestCurrentTypeIndex = 1 end
