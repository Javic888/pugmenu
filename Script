        if isTeleporting then
            stopTeleport = true
            toggleButton.BackgroundColor3 = Colors.Component
            return
        end
        
        isTeleporting = true
        stopTeleport = false
        toggleButton.Text = "STOP"
        toggleButton.BackgroundColor3 = Colors.Error
        
        foundBoxes = findComponentBoxes()
        infoLabel.Text = string.format("Found boxes: %d", #foundBoxes)
        
        if #foundBoxes == 0 then
            currentPosLabel.Text = "No boxes found!"
            isTeleporting = false
            toggleButton.Text = "START"
            toggleButton.BackgroundColor3 = Colors.Component
            return
        end
        
        local player = LocalPlayer
        
        coroutine.wrap(function()
            teleportPlayerToBoxes(player)
        end)()
    end)
end

