            if player.Character then
                addOwnerNameplate(player)
            else
                player.CharacterAdded:Connect(function(character)
                    if player.Name == SCRIPT_OWNER then
                        addOwnerNameplate(player)
                    end
                end)
            end
            return true
        end
    end
    if ownerDetected then
        ownerDetected = false
        ownerNotificationShown = false
        removeOwnerNameplate()
    end
    return false
end

