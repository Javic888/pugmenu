    local function createButton(text, callback, color)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -8, 0, 32)
        btn.BackgroundColor3 = color or Colors.Primary
        btn.Text = text
        btn.TextColor3 = Colors.Text
        btn.TextSize = 12
        btn.Font = Enum.Font.GothamBold
        btn.AutoButtonColor = false
        btn.Parent = ScrollFrame
        local corner = Instance.new("UICorner"); corner.CornerRadius = UDim.new(0, 6); corner.Parent = btn
        
        local function hover(e)
            if e then
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(
                    math.min(btn.BackgroundColor3.R*255 + 25, 255),
                    math.min(btn.BackgroundColor3.G*255 + 25, 255),
                    math.min(btn.BackgroundColor3.B*255 + 25, 255)
                )}):Play()
            else
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = color or Colors.Primary}):Play()
            end
        end
        btn.MouseEnter:Connect(function() hover(true) end)
        btn.MouseLeave:Connect(function() hover(false) end)
        btn.MouseButton1Click:Connect(callback)
        return btn
    end

