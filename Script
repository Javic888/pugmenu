local healthAutoEnabled = false
local healthConnection
local HEALTH_THRESHOLD = 20
local TARGET_CFRAME = CFrame.new(949, 373, 463)

_G.setHealthThreshold = function(newThreshold)
    HEALTH_THRESHOLD = math.clamp(math.floor(newThreshold), 1, 100)
end

_G.manualHealthTeleport = function(healthStatusLabel, healthValueLabel)
    local character = LocalPlayer.Character
    if not character then
        if healthStatusLabel then healthStatusLabel.Text = "Status: Character not found" end
        return false
    end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then
        if healthStatusLabel then healthStatusLabel.Text = "Status: HumanoidRootPart not found" end
        return false
    end
    
    local success = pcall(function()
        humanoidRootPart.CFrame = TARGET_CFRAME
    end)
    
    if success then
        if healthStatusLabel then healthStatusLabel.Text = "Status: Teleported!" end
        return true
    else
        if healthStatusLabel then healthStatusLabel.Text = "Status: Teleport error" end
        return false
    end
end

local function checkHealth(healthStatusLabel, healthValueLabel)
    local character = LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    local currentHealth = humanoid.Health
    local maxHealth = humanoid.MaxHealth
    local healthPercent = math.floor((currentHealth / maxHealth) * 100)
    
    if healthValueLabel then
        healthValueLabel.Text = string.format("Current Health: %d/%d (%d%%)", math.floor(currentHealth), math.floor(maxHealth), healthPercent)
    end
    
    if healthAutoEnabled and currentHealth <= HEALTH_THRESHOLD then
        if healthStatusLabel then healthStatusLabel.Text = "Status: Low HP! Teleporting..." end
        _G.manualHealthTeleport(healthStatusLabel, healthValueLabel)
    end
    
    return currentHealth
end

