local function findAllVehicles()
    local foundVehicles = {}
    local success, folder = pcall(function()
        return workspace.Game.Entities.vehicles
    end)
    
    if success and folder then
        for _, obj in ipairs(folder:GetChildren()) do
            if obj:IsA("Model") then
                table.insert(foundVehicles, obj)
            end
        end
    end
    return foundVehicles
end

local function refreshVehicles(vehicleStatusLabel)
    local vehicles = findAllVehicles()
    if vehicleStatusLabel then
        vehicleStatusLabel.Text = "Status: Vehicles found: " .. #vehicles
    end
    return vehicles
end

_G.startVehicleCycle = function(vehicleStatusLabel)
    if isVehicleRunning then return end
    isVehicleRunning = true
    if vehicleStatusLabel then vehicleStatusLabel.Text = "Status: Vehicle cycle started" end
    
    coroutine.wrap(function()
        while isVehicleRunning do
            local vehicles = refreshVehicles(vehicleStatusLabel)
            
            if #vehicles == 0 then
                if vehicleStatusLabel then vehicleStatusLabel.Text = "Status: Searching vehicles..." end
                task.wait(2)
            else
                if vehicleCurrentIndex > #vehicles then
                    vehicleCurrentIndex = 1
                end
                
                local vehicle = vehicles[vehicleCurrentIndex]
                if vehicle and vehicle.Parent then
                    local character = LocalPlayer.Character
                    if character then
                        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
                        if humanoidRootPart then
                            local targetPart = vehicle.PrimaryPart or vehicle:FindFirstChildWhichIsA("BasePart")
                            if targetPart then
                                humanoidRootPart.CFrame = targetPart.CFrame + Vector3.new(0, 5, 0)
                                if vehicleStatusLabel then
                                    vehicleStatusLabel.Text = "Status: " .. vehicle.Name .. " " .. vehicleCurrentIndex .. "/" .. #vehicles
                                end
                            end
                        end
                    end
                    
                    vehicleCurrentIndex = vehicleCurrentIndex + 1
                end
                
                for i = 3, 1, -1 do
                    if not isVehicleRunning then break end
                    local currentVehicles = findAllVehicles()
                    if vehicleStatusLabel then
                        vehicleStatusLabel.Text = "Status: " .. vehicleCurrentIndex .. "/" .. #currentVehicles .. " - " .. i .. "s"
                    end
                    task.wait(1)
                end
            end
            
            if not isVehicleRunning then break end
            task.wait()
        end
        
        if vehicleStatusLabel then vehicleStatusLabel.Text = "Status: Vehicle cycle stopped" end
    end)()
end

_G.stopVehicleCycle = function()
    isVehicleRunning = false
end

-- ============================================
-- E SPAMMER SYSTEM
-- ============================================
local eSpammerConnection = nil
local wasInSafeZone = false
local eSpammerEnabled = false

local SAFE_ZONE = {
    center = Vector3.new(949, 373, 463),
    radius = 50
}

local function checkSafeZone()
    local character = LocalPlayer.Character
    if not character then return false end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return false end
    
    local distance = (humanoidRootPart.Position - SAFE_ZONE.center).Magnitude
    return distance < SAFE_ZONE.radius
end

local function startESpammer(eSpammerStatusLabel)
    if eSpammerConnection then
        eSpammerConnection:Disconnect()
        eSpammerConnection = nil
    end
    
    eSpammerConnection = RunService.Heartbeat:Connect(function()
        if not eSpammerEnabled then
            return
        end
        
        local inSafeZone = checkSafeZone()
        
        if inSafeZone then
            if eSpammerStatusLabel then
                eSpammerStatusLabel.Text = "Status: Auto-disabled (Safe Zone)"
            end
            return
        end
        
        if eSpammerStatusLabel then
            eSpammerStatusLabel.Text = "Status: Auto-spamming"
        end
        
        local virtualInput = game:GetService("VirtualInputManager")
        pcall(function()
            virtualInput:SendKeyEvent(true, "E", false, game)
            task.wait(0.05)
            virtualInput:SendKeyEvent(false, "E", false, game)
        end)
        
        task.wait(0.1)
    end)
end

_G.toggleESpammer = function(state, eSpammerStatusLabel)
    eSpammerEnabled = state
    
    if eSpammerEnabled then
        if checkSafeZone() then
            if eSpammerStatusLabel then
                eSpammerStatusLabel.Text = "Status: Cannot enable in Safe Zone!"
            end
            eSpammerEnabled = false
            return
        end
        
        if eSpammerStatusLabel then
            eSpammerStatusLabel.Text = "Status: Enabled"
        end
        
        startESpammer(eSpammerStatusLabel)
        
        coroutine.wrap(function()
            while eSpammerEnabled do
                task.wait(1)
                
                if checkSafeZone() then
                    wasInSafeZone = true
                    if eSpammerStatusLabel then
                        eSpammerStatusLabel.Text = "Status: Auto-disabled (Safe Zone)"
                    end
                elseif wasInSafeZone then
                    wasInSafeZone = false
                    startESpammer(eSpammerStatusLabel)
                    if eSpammerStatusLabel then
                        eSpammerStatusLabel.Text = "Status: Auto-enabled outside Safe Zone"
                    end
                end
            end
        end)()
    else
        if eSpammerStatusLabel then
            eSpammerStatusLabel.Text = "Status: Disabled"
        end
        
        wasInSafeZone = false
        if eSpammerConnection then
            eSpammerConnection:Disconnect()
            eSpammerConnection = nil
        end
    end
end

