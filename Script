        local foundItems = {}
        
        for _, item in ipairs(itemPickups) do
            if item:GetAttribute("itemName") == "Component Box" then
                local position = item:GetPivot().Position
                table.insert(foundItems, {
                    item = item,
                    position = position + Vector3.new(0, ABOVE_BOX_HEIGHT, 0)
                })
            end
        end
        
        return foundItems
    end
    
